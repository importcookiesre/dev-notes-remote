		},
		{"id":"f8a87635cd90a77d","type":"file","file":"3-database-design-internals/database_internals/storage-engine/strorage-architecture/heap-storage-architecture.md","x":960,"y":20,"width":880,"height":820},
		{
			"id":"d617b01863565fc1",
			"type":"text",
			"text":"# Storage Engine\n",
			"styleAttributes":{},
			"x":-1600,
			"y":-40,
